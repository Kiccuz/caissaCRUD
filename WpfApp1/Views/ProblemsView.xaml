<UserControl x:Class="CaissaApp.Views.ProblemsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:CaissaApp.Components">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- BUTTON -->
        <Grid Background="#8D8DFD">
        <Button Content="Carica problemi"
                Command="{Binding LoadProblemsCommand}"
                Width="150"
                Height="40"
                HorizontalAlignment="Left"/>
        </Grid>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">
        <!-- LISTA -->
        <ItemsControl  
                      ItemsSource="{Binding Problems}"
                      Margin="0,10,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
 
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                        <Button Command="{Binding DataContext.OpenProblemCommand,
                     RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0">
                            <components:Problem  />
                   </Button>         
                </DataTemplate>
            </ItemsControl.ItemTemplate>

        </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>