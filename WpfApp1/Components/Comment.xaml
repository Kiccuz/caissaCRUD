<UserControl x:Class="CaissaApp.Components.Comment"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CaissaApp.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
   
        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <Image Width="30"
               Height="30"
               Grid.Column="0"
               Source="/Assets/comment.png"
               Stretch="UniformToFill"/>

        <StackPanel Grid.Column="1" Margin="10,0,0,0">

                <TextBlock Text="{Binding ProblemId}"
               Foreground="LightGray"/>

                <TextBlock Text="{Binding CreatedAt, StringFormat=dd/MM/yyyy}"
               Foreground="LightGray"/>

                <TextBlock Text="{Binding Text}"
               Foreground="Red"
               TextWrapping="Wrap"/>

            </StackPanel>
        </Grid>
     
</UserControl>
